{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "addLabels": [
    "renovate",
    "skip-changelog"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "FluentAssertions"
      ],
      "enabled": false
    },
    {
      "groupName": "NUnit packages",
      "matchPackageNames": [
        "NUnit",
        "NUnit.Analyzers",
        "NUnit3TestAdapter"
      ]
    },
    {
      "groupName": "Test SDK",
      "matchPackageNames": [
        "Microsoft.NET.Test.Sdk",
        "Microsoft.TestPlatform.TestHost"
      ]
    }
  ]
}
